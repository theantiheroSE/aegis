{
  "transfer": "ssh",

  "ssh": {
    "host": "backup.example.com",
    "port": 22,
    "user": "backup",
    "identityFile": "/root/.ssh/aegis_ed25519",
    "remoteDir": "/backups/aegis"
  },

  "ftp": {
    "host": "ftp.example.com",
    "port": 21,
    "user": "backup",
    "password": "change-me",
    "remoteDir": "/backups/aegis",
    "secure": false
  },

  "rclone": {
    "remote": "mys3",
    "path": "backups/aegis"
  },

  "localStagingDir": "/var/backups/aegis/staging",
  "localArchiveDir": "/var/backups/aegis/archive",

  "retention": {
    "daily": 7,
    "weekly": 4,
    "monthly": 6
  },
  "retentionDays": 7,
  "retentionKeepLast": 0,

  "notifications": {
    "onSuccess": false,
    "onFailure": true,
    "webhook": {
      "url": "https://hooks.slack.com/services/XXX/YYY/ZZZ",
      "method": "POST",
      "headers": { "Content-Type": "application/json" },
      "secret": ""
    },
    "email": {
      "to": "ops@example.com",
      "from": "aegis@example.com"
    },
    "smtp": {
      "host": "smtp.gmail.com",
      "port": 587,
      "secure": false,
      "user": "user@gmail.com",
      "pass": "app-password",
      "from": "user@gmail.com",
      "to": "ops@example.com"
    },
    "healthcheckUrl": "https://hc-ping.com/your-uuid-here"
  },

  "encryption": {
    "recipients": [],
    "identityFiles": []
  },

  "hooks": {
    "preBackup": [],
    "postBackup": [],
    "preUpload": [],
    "postUpload": []
  },

  "postgres": {
    "enabled": true,
    "host": "/var/run/postgresql",
    "port": 5432,
    "user": "postgres",
    "runAs": "postgres",
    "bin": "pg_dump",
    "excludeDatabases": ["template0", "template1"],
    "excludeOwners": []
  },

  "mysql": {
    "enabled": false,
    "host": "localhost",
    "port": 3306,
    "user": "root",
    "password": "",
    "runAs": "",
    "bin": "mysql",
    "dumpBin": "mysqldump",
    "excludeDatabases": ["information_schema", "mysql", "performance_schema", "sys"]
  },

  "redis": {
    "enabled": false,
    "host": "localhost",
    "port": 6379,
    "password": "",
    "runAs": "",
    "bin": "redis-cli",
    "path": "/var/lib/redis"
  },

  "mongodb": {
    "enabled": false,
    "host": "localhost",
    "port": 27017,
    "user": "",
    "password": "",
    "authSource": "admin",
    "db": "",
    "runAs": "",
    "dumpBin": "mongodump",
    "restoreBin": "mongorestore"
  },

  "aegis": {
    "enabled": false
  },

  "sqlite": {
    "enabled": true,
    "searchPaths": ["/var/www", "/root", "/opt"],
    "maxDepth": 6,
    "patterns": ["*.db", "*.sqlite", "*.sqlite3"],
    "excludePaths": [
      "/root/.local/share/opencode",
      "/root/.pm2",
      "/root/.cache",
      "/root/.npm",
      "/var/www/html",
      "/var/www/node_modules"
    ]
  },

  "pm2": {
    "enabled": true,
    "excludeDirs": [
      "node_modules",
      ".git",
      ".next",
      ".nuxt",
      "dist",
      "build",
      ".cache",
      ".turbo",
      "coverage",
      ".pnpm-store",
      "logs",
      "*.log"
    ]
  },

  "nginx": {
    "enabled": true,
    "sitesAvailable": "/etc/nginx/sites-available",
    "sitesEnabled": "/etc/nginx/sites-enabled",
    "confDir": "/etc/nginx/conf.d",
    "mainConfig": "/etc/nginx/nginx.conf"
  },

  "extraPaths": [
    "/etc/letsencrypt",
    "/root/config"
  ],

  "archive": {
    "compression": "zstd",
    "compressionLevel": 3,
    "compressionByPhase": {
      "pm2": 19,
      "postgres": 3,
      "sqlite": 3,
      "mysql": 9,
      "nginx": 19,
      "extras": 9,
      "aegis": 19
    }
  },

  "logging": {
    "dir": "/root/bluecode/tools/backup/logs",
    "keepDays": 30
  }
}
